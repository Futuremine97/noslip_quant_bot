{
  "name": "noslip",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.js",
  "bin": {
    "noslip": "./bin/noslip.js"
  },
  "scripts": {
    "dev": "next dev",
    "dev:sp500": "NEXT_PUBLIC_SP500_ONLY=true next dev",
    "build": "next build",
    "build:sp500": "NEXT_PUBLIC_SP500_ONLY=true next build",
    "start": "next start",
    "server": "node server/index.js",
    "lint": "eslint",
    "test": "vitest run",
    "test:live": "vitest run --config vitest.live.config.ts",
    "contracts:compile": "npm --prefix contracts run compile",
    "contracts:test": "npm --prefix contracts test",
    "desktop:build": "electron-builder --mac --win",
    "cli:link": "npm link"
  },
  "dependencies": {
    "@tosspayments/payment-sdk": "^1.9.2",
    "autoprefixer": "^10.4.27",
    "axios": "^1.15.2",
    "next": "16.2.6",
    "postcss": "^8.5.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "viem": "^2.52.2"
  },
  "overrides": {
    "follow-redirects": "1.16.0",
    "postcss": "$postcss"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4.2.2",
    "typescript": "^5",
    "vitest": "^4.1.4"
  },
  "build": {
    "appId": "com.noslip.app",
    "productName": "NoSlipQuant",
    "asar": false,
    "icon": "electron/icon.png",
    "mac": {
      "category": "public.app-category.finance",
      "target": [
        "dmg"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "directories": {
      "output": "dist-desktop"
    },
    "files": [
      "package.json",
      "electron/**/*",
      "build/**/*",
      ".next/**/*",
      "!.next/cache/**/*",
      "server/**/*",
      "public/**/*",
      "node_modules/**/*"
    ]
  }
}
