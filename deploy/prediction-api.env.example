PREDICTION_API_TOKEN=replace_with_a_long_random_secret
MPLCONFIGDIR=/tmp/no-slip-matplotlib
ENABLE_TIMESFM_DRAWDOWN=true
TIMESFM_REPO_PATH=/opt/timesfm
TIMESFM_MODEL_ID=google/timesfm-2.5-200m-pytorch
ENABLE_RESOURCE_MOE=true
MOE_PROFILE=balanced
MOE_MAX_HEAVY_IN_FLIGHT=1
MOE_FORCE_EXPERTS=
MOE_DISABLE_EXPERTS=
